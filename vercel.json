{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy?path=api/:path*" },
    { "source": "/login/:path*", "destination": "/api/proxy?path=login/:path*" },
    { "source": "/register/:path*", "destination": "/api/proxy?path=register/:path*" },
    { "source": "/refresh/:path*", "destination": "/api/proxy?path=refresh/:path*" },
    { "source": "/forgotPassword/:path*", "destination": "/api/proxy?path=forgotPassword/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
