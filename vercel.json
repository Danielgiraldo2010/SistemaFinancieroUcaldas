{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy?path=api/:path*" },
    { "source": "/login", "destination": "/api/proxy?path=login" },
    { "source": "/register", "destination": "/api/proxy?path=register" },
    { "source": "/forgotPassword", "destination": "/api/proxy?path=forgotPassword" },
    { "source": "/refresh", "destination": "/api/proxy?path=refresh" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
